20. Static vs dynamic binding?
Static → compile time , Early Binding
Dynamic → runtime , Late Binding

<?php
class Test {
    public static function show() {
        echo "Static binding\n";
    }

    public static function callShow() {
        self::show();  // early binding		output-> Static binding		
		(Even though method is overridden, parent method is called, Because self:: binds to the class where it is defined)
		static::show();  // late binding   	output-> Overridden method	(Here child class method is called)
    }
}

class Demo extends Test {
    public static function show() {
        echo "Overridden method\n";
    }
}

Demo::callShow();
?>


